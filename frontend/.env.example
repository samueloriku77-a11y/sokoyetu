# Frontend Environment Configuration
# Copy this to frontend/ and rename to .env.local

# API Configuration
VITE_API_URL=http://localhost:8000
VITE_API_TIMEOUT=10000

# Application Settings
VITE_APP_NAME=SokoYetu
VITE_APP_VERSION=1.0.0

# Map Configuration (Google Maps - optional)
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Geolocation Options
VITE_GEOLOCATION_TIMEOUT=5000
VITE_GEOLOCATION_MAX_AGE=0

# Feature Flags
VITE_ENABLE_MAPS=true
VITE_ENABLE_GEOFENCING=true
VITE_ENABLE_QR_SCANNER=true
VITE_ENABLE_LOCATION_TRACKING=true
VITE_ENABLE_NOTIFICATIONS=true

#intasend
INTASEND_API_URL=https://api.intasend.co/v1
INTASEND_API_KEY=your_api_key
INTASEND_API_SECRET=your_api_secret
INTASEND_CALLBACK_URL=https://yourdomain.com/api/wallet/callback
