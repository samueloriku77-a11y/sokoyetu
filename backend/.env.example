# SokoYetu Backend Environment Configuration
# Copy this to .env and fill in your values

# DATABASE CONFIGURATION

# Choose database type (sqlite, postgresql, or mysql)
DATABASE_TYPE=sqlite

# SQLite (Default - no additional config needed)
# DATABASE_URL=sqlite:///./sokoyetu.db

# PostgreSQL Configuration
# DATABASE_TYPE=postgresql
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=your_password
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=sokoyetu

# MySQL Configuration
# DATABASE_TYPE=mysql
# MYSQL_USER=root
# MYSQL_PASSWORD=your_password
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_DB=sokoyetu

# JWT & SECURITY
SECRET_KEY=your-super-secret-key-change-in-production-DO-NOT-SHARE
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# M-PESA / PAYMENT (Daraja API)
MPESA_CONSUMER_KEY=sandbox_consumer_key
MPESA_CONSUMER_SECRET=sandbox_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=sandbox_passkey
MPESA_CALLBACK_URL=https://yourdomain.com/api/mpesa/callback

# NOTIFICATIONS
AFRICASTALKING_API_KEY=sandbox_key
AFRICASTALKING_USERNAME=sandbox
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-specific-password

# FILE UPLOADS
UPLOAD_DIR=./uploads

# APPLICATION
ENVIRONMENT=development
DEBUG=True
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

